# URL проекта Supabase
SUPABASE_URL=https://prhiqnxuqgrsxzjrxhht.supabase.co

# Секретный ключ service_role (Supabase → Project Settings → API → service_role).
# ВНИМАНИЕ: только на сервере. Никогда не клади его во фронтенд и не коммить.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres-схема приложения (изоляция от CRM в общем проекте)
SUPABASE_SCHEMA=anki

# Порт REST API
PORT=3000

# Разрешённый источник CORS (фронтенд). По умолчанию — любой.
CORS_ORIGIN=*
